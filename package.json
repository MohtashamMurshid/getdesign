{
  "name": "getdesign",
  "private": true,
  "version": "0.1.0",
  "description": "On-demand design systems from any URL",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "bun run --cwd ./packages/types build"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@getdesign/config": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "studio": "workspace:*",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@getdesign/tools": "workspace:*",
    "@getdesign/types": "workspace:*",
    "ai": "^6.0.168",
    "convex": "^1.35.1",
    "zod": "^4.3.6"
  }
}
