{
  "name": "studio",
  "version": "0.1.1",
  "private": true,
  "description": "getdesign Studio - Electron desktop app",
  "main": "./out/main/index.js",
  "author": {
    "name": "Mohtasham Murshid",
    "email": "mohtashammurshid@gmail.com"
  },
  "homepage": "https://github.com/MohtashamMurshid/getdesign",
  "repository": {
    "type": "git",
    "url": "https://github.com/MohtashamMurshid/getdesign.git",
    "directory": "apps/studio"
  },
  "trustedDependencies": [
    "electron",
    "electron-winstaller",
    "esbuild"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "release": "electron-vite build && electron-builder --publish always",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "release:win": "electron-vite build && electron-builder --win --publish always",
    "release:linux": "electron-vite build && electron-builder --linux --publish always",
    "version:patch": "node scripts/version.mjs patch",
    "version:minor": "node scripts/version.mjs minor",
    "version:major": "node scripts/version.mjs major",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "clean": "rm -rf out dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@mariozechner/pi-ai": "^0.70.5",
    "@mariozechner/pi-coding-agent": "^0.70.5",
    "@pierre/diffs": "^1.1.19",
    "@streamdown/code": "^1.1.1",
    "@tabler/icons-react": "^3.41.1",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.3.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.12.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "shadcn": "^4.6.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
