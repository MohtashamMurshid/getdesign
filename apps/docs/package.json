{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "bun run reference && astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "reference": "bun run reference:sdk && bun run reference:cli",
    "reference:sdk": "echo '[docs] SDK reference is generated by starlight-typedoc during astro build'",
    "reference:cli": "bun run scripts/generate-cli-reference.ts",
    "clean": "rm -rf dist .astro node_modules/.astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/starlight": "^0.36.0",
    "@fontsource-variable/geist": "^5.2.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.0",
    "@getdesign/cli": "workspace:*",
    "@getdesign/sdk": "workspace:*",
    "astro": "^5.15.0",
    "sharp": "^0.33.5",
    "starlight-typedoc": "^0.21.5",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.4.0"
  },
  "devDependencies": {
    "@getdesign/config": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^5.6.3"
  }
}
